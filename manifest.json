{
  "manifest_version": 3,
  "name": "chrome-goods-download",
  "version": "1.0.0",
  "description": "Extract and download product images from Taobao/Tmall pages",
  "permissions": [
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.taobao.com/*",
    "*://*.tmall.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/logo.png",
      "32": "icons/logo.png",
      "48": "icons/logo.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.taobao.com/*", "*://*.tmall.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}
    